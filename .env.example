# ─── Required ──────────────────────────────────────────────────────────────

# Which COPE environment this deploy targets. Picks API + checkout URLs.
#   prod | stg | qa | dpa
COPE_ENV=stg

# Browser-safe key. Get it from Dashboard → Settings → Developers → API keys.
# Prefix `cope_pk_…`. Visible in HTML; never put a `cope_sk_…` here.
COPE_PUBLISHABLE_KEY=cope_pk_REPLACE_ME

# UUID of the product to sell. Create one in the dashboard test catalog.
COPE_PRODUCT_UUID=prod_REPLACE_ME

# Server-side secret for webhook signature verification. Returned ONCE by
# `POST /v1/webhooks/endpoints` when you register the endpoint.
COPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Public URL this app is reachable at — used for success_url, cancel_url, and
# the webhook endpoint you register with COPE.
#
# MUST be HTTPS when COPE_ENV != prod with a local hostname: staging rejects
# http://localhost-style success_url ("must use HTTPS"). For local development
# use a tunnel (cloudflared / ngrok / localtunnel) and put its HTTPS URL here.
# After Vercel/Railway deploy, set this to the URL the platform assigned you
# (e.g. https://cope-integration-samples.vercel.app) and redeploy.
PUBLIC_BASE_URL=http://localhost:4000

# ─── Optional ──────────────────────────────────────────────────────────────

COPE_DEFAULT_CURRENCY=EUR

# Override the URLs derived from COPE_ENV. Only needed when targeting a custom
# deployment (private staging, self-hosted gateway, etc.).
# COPE_API_BASE=https://stg.cope-demo.com/gateway/cart_api
# COPE_CHECKOUT_BASE=https://stg.cope-demo.com
