# ─── Always required ───────────────────────────────────────────────────────

# Browser-safe key. Get it from Dashboard → Settings → Developers → API keys.
# Prefix `cope_pk_…`. Visible in HTML; never put a `cope_sk_…` here. Used by
# the catalog page to authenticate the cart SDK in the browser.
COPE_PUBLISHABLE_KEY=cope_pk_REPLACE_ME

# Server-only API key (`cope_sk_live_*` / `cope_sk_test_*`). One key, two
# scopes — mint it in Dashboard → Settings → Developers → API keys:
#   - `commerce:products:read` — for /catalog to fetch GET /v1/commerce/products
#   - `webhooks:write`         — for the `pnpm register` script (one-time setup)
# Never exposed to the browser — read only by Server Components and Node scripts.
COPE_API_KEY=cope_sk_REPLACE_ME

# Public URL this app is reachable at — used for success_url, cancel_url, and
# the webhook endpoint you register with COPE. For local development use a
# tunnel (cloudflared / ngrok / localtunnel) and put its HTTPS URL here.
# After Vercel/Railway deploy, leave this blank — the platform's URL is picked
# up automatically from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL /
# RAILWAY_PUBLIC_DOMAIN.
PUBLIC_BASE_URL=http://localhost:4000

# ─── Required for /api/webhooks/cope ───────────────────────────────────────
#
# Webhook receiver. Drop these two if you don't need signed event delivery.

# Returned ONCE by `POST /v1/webhooks/endpoints` when you register the
# endpoint. Without it the route returns HTTP 503 "receiver not configured".
COPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── Optional ──────────────────────────────────────────────────────────────

# Default currency the catalog page starts with. Falls back to EUR.
COPE_DEFAULT_CURRENCY=EUR

# Override the production URLs. Only needed when targeting a custom deployment
# (private staging, self-hosted gateway, etc.).
# COPE_API_BASE=https://api.cope.com
# COPE_CHECKOUT_BASE=https://cope.com
